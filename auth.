*{
margin:0;
padding:0;
box-sizing:border-box;
}


body{

font-family:'Poppins',sans-serif;

}



.auth-page{

height:100vh;

display:flex;

justify-content:center;

align-items:center;

background:
linear-gradient(135deg,#ff4d8d,#8b5cf6);

}



.auth-card{

width:430px;

background:white;

padding:45px;

border-radius:30px;

box-shadow:
0 30px 80px rgba(0,0,0,.2);

text-align:center;

}



.logo{

font-size:40px;

font-weight:700;

color:#ff4d8d;

margin-bottom:20px;

}



.auth-card h1{

font-size:32px;

margin-bottom:10px;

}



.auth-card p{

color:#777;

margin-bottom:30px;

}



.input-box input{

width:100%;

padding:16px;

margin-bottom:15px;

border-radius:15px;

border:1px solid #ddd;

font-size:16px;

}



form button{

width:100%;

padding:16px;

border:none;

border-radius:50px;

background:
linear-gradient(45deg,#ff4d8d,#ff85b3);

color:white;

font-size:17px;

font-weight:600;

cursor:pointer;

}



.line{

margin:25px 0;

color:#999;

}



.google-btn{

width:100%;

padding:15px;

border-radius:50px;

border:1px solid #ddd;

background:white;

font-size:16px;

cursor:pointer;

}



.bottom{

margin-top:25px;

}



.bottom a{

color:#ff4d8d;

text-decoration:none;

font-weight:600;

}
